{
  "version": 2,
  "functions": {
    "src/AI/main.py": {
      "runtime": "python@3.12",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/ai/(.*)",
      "destination": "/src/AI/main.py"
    },
    {
      "source": "/docs",
      "destination": "/src/AI/main.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/src/AI/main.py"
    }
  ]
}